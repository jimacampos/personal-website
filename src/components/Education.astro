---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-2">
              Education
            </h2>
            <div
              class="w-[75px] h-[5px] rounded-full mb-4"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            <button
              id="education-toggle"
              class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-sm font-medium transition-all duration-200 hover:opacity-80 cursor-pointer mb-4 lg:mb-0"
              style={`border-color: ${siteConfig.accentColor}; color: ${siteConfig.accentColor}`}
              aria-label="Toggle education section"
            >
              <svg id="education-toggle-icon" class="w-4 h-4 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
              <span id="education-toggle-label">Collapse</span>
            </button>
          </div>

          <div class="lg:col-span-8">
            <div id="education-content" class="space-y-8 transition-all duration-500 overflow-hidden">
              {siteConfig.education.map((edu) => (
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                      <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                        {edu.degree}
                      </h3>
                      <p
                        class="text-base sm:text-lg"
                        style={`color: ${siteConfig.accentColor}`}
                      >
                        {edu.school}
                      </p>
                    </div>
                    <span class="text-xs sm:text-sm text-gray-500 mt-2 sm:mt-0">
                      {edu.dateRange}
                    </span>
                  </div>
                </div>
              ))}

              <div id="education-collapse-btn-wrapper" class="flex justify-center">
                <button
                  id="education-collapse-btn"
                  class="flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-medium transition-all duration-200 hover:opacity-80"
                  style={`border-color: ${siteConfig.accentColor}; color: ${siteConfig.accentColor}`}
                >
                  <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                  Collapse
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggleButton = document.getElementById('education-toggle');
    const collapseBtn = document.getElementById('education-collapse-btn');
    const content = document.getElementById('education-content');
    const icon = document.getElementById('education-toggle-icon');
    const label = document.getElementById('education-toggle-label');

    if (!toggleButton || !content || !icon) return;

    let isCollapsed = false;
    let contentHeight = content.scrollHeight;

    content.style.maxHeight = contentHeight + 'px';
    icon.style.transform = 'rotate(180deg)';

    function collapse() {
      content.style.maxHeight = '0px';
      icon.style.transform = 'rotate(0deg)';
      if (label) label.textContent = 'Expand';
      isCollapsed = true;
    }

    function expand() {
      contentHeight = content.scrollHeight;
      content.style.maxHeight = contentHeight + 'px';
      icon.style.transform = 'rotate(180deg)';
      if (label) label.textContent = 'Collapse';
      isCollapsed = false;
    }

    toggleButton.addEventListener('click', function() {
      isCollapsed ? expand() : collapse();
    });

    collapseBtn?.addEventListener('click', function() {
      collapse();
      toggleButton.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    window.addEventListener('resize', function() {
      if (!isCollapsed) {
        contentHeight = content.scrollHeight;
        content.style.maxHeight = contentHeight + 'px';
      }
    });
  });
</script>
